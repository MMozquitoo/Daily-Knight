{
  "buildCommand": "",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/morning",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/plan-week",
      "schedule": "0 19 * * 0"
    },
    {
      "path": "/api/cron/evening",
      "schedule": "0 18 * * *"
    }
  ]
}
